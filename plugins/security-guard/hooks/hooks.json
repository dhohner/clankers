{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'if [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ] && [ -f \"${CLAUDE_PLUGIN_ROOT}/scripts/block-fups.sh\" ]; then exec bash \"${CLAUDE_PLUGIN_ROOT}/scripts/block-fups.sh\"; fi'",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
