{
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "bash -lc 'if [ -n \"${CLAUDE_PLUGIN_ROOT:-}\" ] && [ -f \"${CLAUDE_PLUGIN_ROOT}/scripts/block-package-managers.sh\" ]; then exec bash \"${CLAUDE_PLUGIN_ROOT}/scripts/block-package-managers.sh\"; fi'",
        "timeout": 5
      }
    ]
  }
}
