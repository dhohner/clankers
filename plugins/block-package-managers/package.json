{
  "name": "block-package-managers",
  "version": "0.1.0",
  "private": true,
  "description": "Pi extension and Claude-format hook that block npm and npx terminal usage and redirect to pnpm.",
  "keywords": [
    "pi-package",
    "pnpm",
    "guardrails",
    "hooks"
  ],
  "license": "MIT",
  "author": {
    "name": "dhohner"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/dhohner/clankers.git",
    "directory": "plugins/block-package-managers"
  },
  "scripts": {
    "test": "pnpm test:shell && pnpm test:unit",
    "test:shell": "pnpm dlx bats test/*.bats",
    "test:unit": "pnpm exec vitest run"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "vitest": "^4.1.5"
  },
  "pi": {
    "extensions": [
      "./extensions/block-package-managers.ts"
    ]
  },
  "files": [
    "README.md",
    "extensions/**",
    "scripts/**",
    "package.json",
    "LICENSE"
  ]
}
